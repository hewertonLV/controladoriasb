APP_NAME="SB - CONTROLADORIA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Vazio = URL automática (host do navegador ou IPv4 do servidor + APP_PORT abaixo).
# Só preencha se precisar forçar um endereço fixo (ex.: domínio público com HTTPS).
APP_URL=

# Portas publicadas no host (docker compose)
APP_PORT=44432
MYSQL_PORT=44433
PHPMYADMIN_PORT=44434

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_TIMEZONE=America/Sao_Paulo
DB_TIMEZONE=-03:00
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Diagnóstico temporário de requisições lentas (storage/logs/request-debug.jsonl)
REQUEST_DEBUG_ENABLED=true
REQUEST_DEBUG_CLIENT_TRACKING=true
REQUEST_DEBUG_SLOW_MS=2000
REQUEST_DEBUG_LOG_QUERIES=true
REQUEST_DEBUG_MAX_QUERIES=50
REQUEST_DEBUG_SLOW_QUERY_MS=100
REQUEST_DEBUG_HIGH_QUERY_COUNT=30
REQUEST_DEBUG_REPEATED_QUERY_MIN=5
REQUEST_DEBUG_HIGH_MEMORY_MB=128

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=controladoriasb
DB_USERNAME=
DB_PASSWORD=

# Backup automático MySQL (php artisan db:backup — agendado 01:00 America/Sao_Paulo)
BACKUP_ENABLED=true
BACKUP_PATH=backups/database
BACKUP_RETENTION_DAYS=14
BACKUP_DAILY_AT=01:00
BACKUP_TIMEOUT=3600

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
